#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    draw_borders: false,
    show_song_table_header: false,
    symbols: (song: "🎵", dir: "📁", playlist: "🎼", marker: "\u{e0b0}"),
    layout: Split(
        direction: Vertical,
        panes: [
            (
                pane: Pane(Header),
                size: "1",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                pane: Pane(ProgressBar),
                size: "1",
            ),
        ],
    ),
    progress_bar: (
        symbols: ["", "", "⭘", " ", " "],
        track_style: (bg: None),
        elapsed_style: (fg: "#f5c2e7", bg: None),
        thumb_style: (fg: "#f5c2e7", bg: None),
    ),
    scrollbar: (
        symbols: ["│", "█", "▲", "▼"],
        track_style: (fg: "#e2eefc"),
        ends_style: (fg: "#e2eefc"),
        thumb_style: (fg: "#f5c2e7"),
    ),
    browser_column_widths: [20, 38, 42],
    text_color: "#e2eefc",
    background_color: None,
    header_background_color: None,
    modal_background_color: None,
    modal_backdrop: false,
    tab_bar: (active_style: (fg: "black", bg: "#f5c2e7", modifiers: "Bold"), inactive_style: ()),
    borders_style: (fg: "#e2eefc"),
    highlighted_item_style: (fg: "#f5c2e7", modifiers: "Bold"),
    current_item_style: (fg: "black", bg: "#f5c2e7", modifiers: "Bold"),
    highlight_border_style: (fg: "#f5c2e7"),
    song_table_format: [
        (
            prop: (kind: Property(Artist), style: (fg: "#e2eefc"), default: (kind: Text("Unknown"))),
            width: "50%",
            alignment: Right,
        ),
        (
            prop: (kind: Text("-"), style: (fg: "#e2eefc"), default: (kind: Text("Unknown"))),
            width: "1",
            alignment: Center,
        ),
        (
            prop: (kind: Property(Title), style: (fg: "#e2eefc"), default: (kind: Text("Unknown"))),
            width: "50%",
        ),
    ],
    header: (
        rows: [
            (
                left: [
                    (kind: Text("["), style: (fg: "#f5c2e7", modifiers: "Bold")),
                    (kind: Property(Status(State)), style: (fg: "#f5c2e7", modifiers: "Bold")),
                    (kind: Text("]"), style: (fg: "#f5c2e7", modifiers: "Bold"))
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "#f5c2e7", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "#f5c2e7", modifiers: "Bold"))
                    ),
                    (kind: Text(" - ")),
                    (kind: Property(Song(Title)), style: (fg: "#f5c2e7", modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (fg: "#f5c2e7", modifiers: "Bold"))
                    )
                ],
                right: [
                    (kind: Text("Vol: "), style: (fg: "#f5c2e7", modifiers: "Bold")),
                    (kind: Property(Status(Volume)), style: (fg: "#f5c2e7", modifiers: "Bold")),
                    (kind: Text("% "), style: (fg: "#f5c2e7", modifiers: "Bold"))
                ]
            )
        ],
    ),
)
